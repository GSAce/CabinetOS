<UserControl x:Class="CabinetOS.UI.SettingsScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111">



    <!-- SETTINGS LAYOUT -->
    <Grid Margin="40">

        <StackPanel>

            <TextBlock Text="SETTINGS"
                       Foreground="White"
                       FontSize="32"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <Button Content="Display"
                    Style="{StaticResource DarkRoundedButton}"/>

            <Button Content="Audio"
                    Style="{StaticResource DarkRoundedButton}"/>

            <Button Content="Network"
                    Style="{StaticResource DarkRoundedButton}"/>

            <Button Content="Retro Library"
                    Style="{StaticResource DarkRoundedButton}"/>

            <Button Content="Storage"
                    Style="{StaticResource DarkRoundedButton}"/>

            <Button Content="About CabinetOS"
                    Style="{StaticResource DarkRoundedButton}"/>

        </StackPanel>

    </Grid>
</UserControl>