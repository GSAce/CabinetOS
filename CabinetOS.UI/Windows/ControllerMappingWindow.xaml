<Window x:Class="CabinetOS.UI.Windows.ControllerMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CabinetOS.UI.Controls"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF101018"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ActionTitle"
                   Text="Mapping Input"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,20"/>

        <StackPanel Grid.Row="2"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center">

            <TextBlock Text="Press a button or move an axis…"
                       Foreground="#CCCCCC"
                       FontSize="16"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Hold any button for 1 second to skip"
                       Foreground="#888888"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,10"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0">
                <Button x:Name="MapButton"
                        Content="Map"
                        Width="120"
                        Height="32"
                        Margin="0,0,10,0"
                        Click="MapButton_Click"/>
                <Button x:Name="DoneButton"
                        Content="Done"
                        Width="120"
                        Height="32"
                        Click="DoneButton_Click"/>
            </StackPanel>
        </StackPanel>

        <controls:RemapOverlay x:Name="RemapOverlay"
                               Visibility="Collapsed"/>
    </Grid>
</Window>