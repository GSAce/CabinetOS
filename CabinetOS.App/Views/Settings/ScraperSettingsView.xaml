<UserControl x:Class="CabinetOS.App.Views.Settings.Categories.ScraperSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">

            <!-- TITLE -->
            <TextBlock Text="Scraper Settings"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- SCRAPER SELECTOR -->
            <TextBlock Text="Select Scraper"
                       Margin="0,0,0,5"/>

            <ComboBox ItemsSource="{Binding Settings.AvailableScrapers}"
                      SelectedItem="{Binding Settings.SelectedScraper}"
                      Width="200"
                      Margin="0,0,0,20"/>

            <!-- SCREENSCRAPER PANEL -->
            <StackPanel Margin="0,0,0,20"
                        Visibility="{Binding Settings.SelectedScraper, Converter={StaticResource EqualsConverter}, ConverterParameter=ScreenScraper}">

                <TextBlock Text="ScreenScraper Developer Credentials"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <!-- DEVID -->
                <TextBlock Text="Developer ID" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Settings.ScreenScraper.DevId, UpdateSourceTrigger=PropertyChanged}"
                         Width="250"
                         Margin="0,0,0,10"/>

                <!-- DEV PASSWORD -->
                <TextBlock Text="Developer Password" Margin="0,0,0,5"/>
                <PasswordBox Width="250"
                             Margin="0,0,0,10"
                             Password="{Binding Settings.ScreenScraper.DevPasswordPlain, Mode=TwoWay}"/>

                <!-- API KEY -->
                <TextBlock Text="API Key" Margin="0,0,0,5"/>
                <PasswordBox Width="250"
                             Margin="0,0,0,20"
                             Password="{Binding Settings.ScreenScraper.ApiKeyPlain, Mode=TwoWay}"/>

                <TextBlock Text="ScreenScraper User Login"
                           FontWeight="Bold"
                           Margin="0,10,0,10"/>

                <!-- USERNAME -->
                <TextBlock Text="Username" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Settings.ScreenScraper.Username, UpdateSourceTrigger=PropertyChanged}"
                         Width="250"
                         Margin="0,0,0,10"/>

                <!-- USER PASSWORD -->
                <TextBlock Text="User Password" Margin="0,0,0,5"/>
                <PasswordBox Width="250"
                             Password="{Binding Settings.ScreenScraper.UserPasswordPlain, Mode=TwoWay}"/>
            </StackPanel>

            <!-- IGDB PANEL -->
            <StackPanel Margin="0,0,0,20"
                        Visibility="{Binding Settings.SelectedScraper, Converter={StaticResource EqualsConverter}, ConverterParameter=IGDB}">

                <TextBlock Text="IGDB Credentials"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Client ID" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Settings.Igdb.ClientId, UpdateSourceTrigger=PropertyChanged}"
                         Width="250"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Client Secret" Margin="0,0,0,5"/>
                <PasswordBox Width="250"
                             Password="{Binding Settings.Igdb.ClientSecretPlain, Mode=TwoWay}"/>
            </StackPanel>

            <!-- THEGAMESDB PANEL -->
            <StackPanel Margin="0,0,0,20"
                        Visibility="{Binding Settings.SelectedScraper, Converter={StaticResource EqualsConverter}, ConverterParameter=TheGamesDB}">

                <TextBlock Text="TheGamesDB Settings"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <TextBlock Text="API Key" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Settings.TheGamesDb.ApiKey, UpdateSourceTrigger=PropertyChanged}"
                         Width="250"
                         Margin="0,0,0,10"/>

                <CheckBox Content="Enable Fanart"
                          IsChecked="{Binding Settings.TheGamesDb.EnableFanart}"
                          Margin="0,0,0,10"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>