<UserControl x:Class="CabinetOS.UI.SettingsScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111">

    <Grid Margin="40">
        <StackPanel>

            <TextBlock Text="SETTINGS"
                       Foreground="White"
                       FontSize="32"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <Button Content="Display"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="200"
                    Height="60"
                    HorizontalAlignment="Center"
                    Margin="0 0 0 12"/>

            <Button Content="Audio"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="200"
                    Height="60"
                    HorizontalAlignment="Center"
                    Margin="0 0 0 12"/>

            <Button Content="Network"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="200"
                    Height="60"
                    HorizontalAlignment="Center"
                    Margin="0 0 0 12"/>

            <Button Content="Retro Library"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="200"
                    Height="60"
                    HorizontalAlignment="Center"
                    Margin="0 0 0 12"/>

            <Button x:Name="ControllerSettingsButton"
        Content="Controller Settings"
        Style="{StaticResource DarkRoundedButton}"
        Width="200"
        Height="60"
        HorizontalAlignment="Center"
        Margin="0 0 0 12"
        Click="ControllerSettings_Click"/>

            <Button Content="Storage"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="200"
                    Height="60"
                    HorizontalAlignment="Center"
                    Margin="0 0 0 12"/>

            <Button Content="About CabinetOS"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="200"
                    Height="60"
                    HorizontalAlignment="Center"
                    Margin="0 0 0 12"/>

        </StackPanel>
    </Grid>
</UserControl>