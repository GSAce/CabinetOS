<UserControl x:Class="CabinetOS.UI.SystemCarousel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CabinetOS.UI"
             x:Name="Root"
             Focusable="True"
             PreviewKeyDown="OnPreviewKeyDown">

    <UserControl.Resources>
        <local:IndexToSelectedConverter x:Key="IndexToSelectedConverter"/>
    </UserControl.Resources>

    <Grid>
       
        <!-- CENTER HIGHLIGHT FRAME -->
        <Border x:Name="HighlightFrame"
                Width="280"
                Height="160"
                BorderBrush="#66FFFFFF"
                BorderThickness="3"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsHitTestVisible="False"/>

        <!-- MOVING ITEMS -->
        <ScrollViewer x:Name="Scroller"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      Focusable="False">

            <ItemsControl x:Name="ItemsHost"
                          ItemsSource="{Binding DisplayItems, ElementName=Root}"
                          AlternationCount="9999">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <!-- TILE ROOT -->
                        <Grid x:Name="TileRoot"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.LayoutTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.LayoutTransform>

                            <!-- BACKGROUND -->
                            <Border x:Name="ItemBorder"
                                    Width="260"
                                    Height="140"
                                    CornerRadius="8"
                                    Background="#303030"
                                    Opacity="0.5"/>

                            <!-- CONTENT -->
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="220">

                                <!-- SYSTEM NAME -->
                                <Viewbox StretchDirection="DownOnly"
                                         MaxWidth="220"
                                         MaxHeight="48"
                                         HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Viewbox>

                                <!-- CATEGORY -->
                                <Viewbox StretchDirection="DownOnly"
                                         MaxWidth="220"
                                         MaxHeight="20"
                                         Margin="0,4,0,0"
                                         HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Category}"
                                               Foreground="#CCCCCC"
                                               TextAlignment="Center"/>
                                </Viewbox>

                            </StackPanel>
                        </Grid>

                        <!-- SELECTION TRIGGERS -->
                        <DataTemplate.Triggers>

                            <!-- SELECTED -->
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource IndexToSelectedConverter}">
                                        <Binding RelativeSource="{RelativeSource AncestorType=ContentPresenter}"
                                                 Path="(ItemsControl.AlternationIndex)"/>
                                        <Binding Path="SelectedIndex"
                                                 RelativeSource="{RelativeSource AncestorType=local:SystemCarousel}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>

                                <Setter TargetName="ItemBorder" Property="Opacity" Value="1.0"/>
                                <Setter TargetName="TileRoot" Property="LayoutTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.25" ScaleY="1.25"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>

                            <!-- NOT SELECTED -->
                            <DataTrigger Value="False">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource IndexToSelectedConverter}">
                                        <Binding RelativeSource="{RelativeSource AncestorType=ContentPresenter}"
                                                 Path="(ItemsControl.AlternationIndex)"/>
                                        <Binding Path="SelectedIndex"
                                                 RelativeSource="{RelativeSource AncestorType=local:SystemCarousel}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>

                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.5"/>
                                <Setter TargetName="TileRoot" Property="LayoutTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>

                        </DataTemplate.Triggers>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>