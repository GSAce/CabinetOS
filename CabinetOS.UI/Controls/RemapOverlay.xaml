<UserControl x:Class="CabinetOS.UI.Controls.RemapOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CabinetOS.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#AA000000"
             Visibility="Collapsed">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Centered Panel -->
        <Border Grid.Row="1"
                Background="#1A1A1A"
                CornerRadius="20"
                Padding="40"
                Width="800"
                HorizontalAlignment="Center">

            <StackPanel HorizontalAlignment="Center">

                <!-- Title -->
                <TextBlock Text="Rebind Input"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Dynamic Input Name -->
                <TextBlock Text="{Binding CurrentInputName}"
                           FontSize="32"
                           HorizontalAlignment="Center"
                           Foreground="#AAA"
                           Margin="0,0,0,40"/>

                <!-- Instruction -->
                <TextBlock Text="Press the button you want to assign…"
                           FontSize="28"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Cancel Button -->
                <Button Content="Cancel"
                        Width="200"
                        Margin="0,20,0,0"
                        Command="{Binding CancelRemapCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
