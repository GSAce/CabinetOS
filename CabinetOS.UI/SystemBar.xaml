<UserControl x:Class="CabinetOS.UI.SystemBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="40"
             Background="#222">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE: CabinetOS (Start Button) -->
        <Button Grid.Column="0"
                Background="Transparent"
                BorderThickness="0"
                Padding="10,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Click="CabinetOS_Click">
            <TextBlock Text="CabinetOS"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"/>
        </Button>

        <!-- CENTER (optional status text) -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
            <TextBlock x:Name="CenterStatusText"
                       Text=""
                       Foreground="White"
                       FontSize="14"/>
        </StackPanel>

        <!-- RIGHT SIDE: WiFi / Battery / Clock -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,0,10,0">

            <TextBlock Text="WiFi"
                       Foreground="White"
                       Margin="0,0,10,0"/>

            <TextBlock Text="Battery"
                       Foreground="White"
                       Margin="0,0,10,0"/>

            <!-- CLOCK WITH PLACEHOLDER -->
            <TextBlock x:Name="ClockText"
                       Text="00:00"
                       Foreground="White"
                       FontSize="14"/>
        </StackPanel>

    </Grid>
</UserControl>