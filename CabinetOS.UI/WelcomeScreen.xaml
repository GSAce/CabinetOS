<UserControl x:Class="CabinetOS.UI.WelcomeScreen"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#AA000000">

 

    <Grid>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="WELCOME TO CABINETOS"
                       Foreground="White"
                       FontSize="36"
                       FontWeight="Bold"
                       Margin="0,0,0,40"/>

            <Button Content="Retro Library"
                    Style="{StaticResource DarkRoundedButton}"
                    Click="RetroLibrary_Click"
                    Width="300"
                    Height="60"


        HorizontalAlignment="Center"
        Margin="0 0 0 12"
/>

            <Button Content="Arcade Tools"
                    Style="{StaticResource DarkRoundedButton}"
                    Click="ArcadeTools_Click"
                    Width="300"
                    Height="60"


        HorizontalAlignment="Center"
        Margin="0 0 0 12"
/>

            <Button Content="Settings"
                    Style="{StaticResource DarkRoundedButton}"
                    Click="Settings_Click"
                    Width="300"
                    Height="60"


        HorizontalAlignment="Center"
        Margin="0 0 0 12"
/>

        </StackPanel>

    </Grid>

</UserControl>