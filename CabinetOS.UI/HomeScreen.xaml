<UserControl x:Class="CabinetOS.UI.HomeScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CabinetOS.UI"
             Background="#FF101010">

    <UserControl.Resources>

        <!-- Existing converter -->
        <local:GameCountToLabelConverter x:Key="GameCountToLabelConverter"/>

        <!-- Dark rounded button style (smaller version) -->
        <Style x:Key="DarkRoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <!-- Back button -->
            <RowDefinition Height="2*"/>
            <!-- Preview -->
            <RowDefinition Height="*"/>
            <!-- Carousel -->
            <RowDefinition Height="1.5*"/>
            <!-- Metadata -->
        </Grid.RowDefinitions>

        <!-- BACK BUTTON -->
        <Button Grid.Row="0"
                Style="{StaticResource DarkRoundedButton}"
                Content="Back to Main Menu"
                Click="BackToMenu_Click"
                Margin="20,0,0,0"/>

        <!-- PREVIEW AREA -->
        <Border Grid.Row="1"
                Background="#FF202020"
                Margin="40"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="600"
                Height="300">

            <TextBlock Text="{Binding SelectedSystemMetadata.DisplayName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="White"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- CAROUSEL -->
        <Grid Grid.Row="2"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Focusable="False"
              Loaded="CarouselLoaded">

            <local:SystemCarousel x:Name="Carousel"
                                  SelectionChanged="Carousel_SelectionChanged"/>
        </Grid>

        <!-- METADATA AREA -->
        <Border Grid.Row="3"
                Background="#FF181818"
                Margin="40"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="600"
                Height="180">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <!-- Category -->
                <TextBlock Text="{Binding SelectedSystemMetadata.Category, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="#CCCCCC"
                           FontSize="20"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Game Count -->
                <TextBlock FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource GameCountToLabelConverter}">
                            <Binding Path="SelectedSystemMetadata.GameCount"
                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>