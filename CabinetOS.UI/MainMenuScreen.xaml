<UserControl x:Class="CabinetOS.UI.MainMenuScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#00000000">
    <!-- Fully transparent -->

    <UserControl.Resources>

        <!-- Dark rounded button style -->
        <Style x:Key="DarkRoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>


    <!-- SLIDE-OUT PANEL -->
    <Grid HorizontalAlignment="Left"
          VerticalAlignment="Top">

        <Border Background="#1A1A1A"
                Width="260"
                Margin="0,40,0,40"
                CornerRadius="0,10,10,0">

            <StackPanel Margin="20,30,20,20">

                <TextBlock Text="MAIN MENU"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <Button Content="Retro Library"
                        Style="{StaticResource DarkRoundedButton}"
                        Click="RetroLibrary_Click"/>

                <Button Content="Arcade Tools"
                        Style="{StaticResource DarkRoundedButton}"
                        Click="ArcadeTools_Click"/>

                <Button Content="Settings"
                        Style="{StaticResource DarkRoundedButton}"
                        Click="Settings_Click"/>

                <Button Content="Exit to Windows"
                        Style="{StaticResource DarkRoundedButton}"
                        Click="Exit_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>