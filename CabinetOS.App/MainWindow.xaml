<Window x:Class="CabinetOS.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CabinetOS.App.Shell"
        Title="CabinetOS"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FF0A0A0A"
        Width="1920" Height="1080">

    <Grid x:Name="RootGrid">

        <!-- SYSTEM BAR -->
        <Grid x:Name="SystemBarRegion"
              Height="48"
              VerticalAlignment="Top">
            <local:SystemBar x:Name="SystemBarControl"/>
        </Grid>

        <!-- MAIN CONTENT REGION -->
        <Grid x:Name="ContentRegion"
              Margin="0,48,0,0">
            <ContentPresenter x:Name="ModuleHost"/>
        </Grid>

        <!-- WELCOME SCREEN OVERLAY -->
        <Grid x:Name="WelcomeScreenOverlay"
              Background="#AA000000"
              Visibility="Collapsed">
            <local:WelcomeScreen/>
        </Grid>

        <!-- STATUS SIDEBAR -->
        <Grid x:Name="StatusSideBarRegion"
              Width="350"
              HorizontalAlignment="Right"
              VerticalAlignment="Stretch"
              Visibility="Collapsed">
            <local:StatusSideBar x:Name="StatusSideBarControl"/>
        </Grid>

        <!-- HOLOGRAPHIC TAB -->
        <Grid x:Name="HolographicTabRegion"
              Width="300"
              Height="200"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,20,20">
            <local:HolographicTab/>
        </Grid>

    </Grid>
</Window>