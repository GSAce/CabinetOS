<Window x:Class="CabinetOS.UI.Windows.ControllerIdentifyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF101018"
        Width="800"
        Height="500"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Load Xbox icon dictionary -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/CabinetOS.UI;component/Icons/Controller/XboxIcons.Alt.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Pulse animation -->
            <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 From="1" To="1.2"
                                 Duration="0:0:1"
                                 AutoReverse="True"/>
                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 From="1" To="1.2"
                                 Duration="0:0:1"
                                 AutoReverse="True"/>
                <DoubleAnimation Storyboard.TargetName="PulseOpacity"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.6" To="1.0"
                                 Duration="0:0:1"
                                 AutoReverse="True"/>
            </Storyboard>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- Title -->
            <TextBlock Text="Hold A on the controller you want to configure"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,30"/>

            <!-- Pulsing A Button Icon -->
            <Grid Width="140" Height="140" Margin="0,0,0,30">
                <Viewbox Width="140" Height="140"
                         RenderTransformOrigin="0.5,0.5"
                         Opacity="0.8"
                         x:Name="PulseOpacity">
                    <Viewbox.RenderTransform>
                        <ScaleTransform x:Name="PulseScale" ScaleX="1" ScaleY="1"/>
                    </Viewbox.RenderTransform>

                    <!-- Replace with your actual A icon key -->
                    <Image Source="{StaticResource IconXboxA_Alt}"/>
                </Viewbox>
            </Grid>

            <!-- Cancel Button -->
            <Button Content="Cancel"
                    Width="140"
                    Height="36"
                    FontSize="16"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>