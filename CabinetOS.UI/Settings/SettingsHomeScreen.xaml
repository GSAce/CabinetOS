<UserControl x:Class="CabinetOS.UI.Settings.SettingsHomeScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111">

    <Grid Margin="40">

        <StackPanel HorizontalAlignment="Center">

            <!-- TITLE -->
            <TextBlock Text="SETTINGS"
                       Foreground="White"
                       FontSize="36"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <!-- CATEGORY BUTTONS -->
            <Button Content="Display"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="260"
                    Height="60"
                    Margin="0 0 0 14"
                    Click="Display_Click"/>

            <Button Content="Audio"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="260"
                    Height="60"
                    Margin="0 0 0 14"
                    Click="Audio_Click"/>

            <Button Content="Network"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="260"
                    Height="60"
                    Margin="0 0 0 14"
                    Click="Network_Click"/>

            <Button Content="Retro Library"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="260"
                    Height="60"
                    Margin="0 0 0 14"
                    Click="RetroLibrary_Click"/>

            <Button Content="Storage"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="260"
                    Height="60"
                    Margin="0 0 0 14"
                    Click="Storage_Click"/>

            <Button Content="About CabinetOS"
                    Style="{StaticResource DarkRoundedButton}"
                    Width="260"
                    Height="60"
                    Margin="0 0 0 14"
                    Click="About_Click"/>

        </StackPanel>

    </Grid>
</UserControl>