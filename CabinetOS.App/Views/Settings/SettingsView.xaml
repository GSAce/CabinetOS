<UserControl x:Class="CabinetOS.App.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CabinetOS.App.ViewModels.Settings"
             mc:Ignorable="d"
             Background="{StaticResource CabinetBackgroundBrush}">

    <!-- DESIGN-TIME DATACONTEXT (safe) -->
    <d:UserControl.DataContext>
        <vm:SettingsViewModel />
    </d:UserControl.DataContext>

    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT NAVIGATION -->
        <Border Background="{StaticResource CabinetPanelBrush}"
                BorderBrush="{StaticResource CabinetBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10">
            <ListBox ItemsSource="{Binding Categories}"
                     SelectedItem="{Binding SelectedCategory}"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="White">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="14"
                                   Margin="4,6,4,6" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- SPLITTER -->
        <GridSplitter Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{StaticResource CabinetSplitterBrush}" />

        <!-- RIGHT CONTENT -->
        <Border Grid.Column="2"
                Background="{StaticResource CabinetPanelBrush}"
                BorderBrush="{StaticResource CabinetBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="20">

            <ContentControl Content="{Binding SelectedCategory.View}"
                            d:Content="Select a category…" />
        </Border>

        <!-- BOTTOM BAR -->
        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="Load"
                    Width="100"
                    Margin="0,0,10,0"
                    Command="{Binding LoadCommand}" />

            <Button Content="Save"
                    Width="100"
                    Margin="0,0,10,0"
                    Command="{Binding SaveCommand}" />

            <Button Content="Defaults"
                    Width="100"
                    Command="{Binding ResetCommand}" />

        </StackPanel>

    </Grid>
</UserControl>