<UserControl x:Class="CabinetOS.App.Shell.WelcomeScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid>

        <!-- BACKGROUND -->
        <Grid x:Name="BackgroundRegion">
            <Rectangle Fill="#222"/>
        </Grid>

        <!-- CENTER POPUP -->
        <Grid x:Name="CenterPopup"
              Width="600"
              Height="500"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Background="#111111">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Select Module"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <Grid Grid.Row="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Designer -->
                <Border Grid.Row="0" Background="#333" Height="60" Margin="0,20,0,0"
                        MouseDown="Designer_Click">
                    <TextBlock Text="Designer"
                               Foreground="White"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Mapping -->
                <Border Grid.Row="1" Background="#333" Height="60" Margin="0,20,0,0"
                        MouseDown="Mapping_Click">
                    <TextBlock Text="Mapping"
                               Foreground="White"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Bezel -->
                <Border Grid.Row="2" Background="#333" Height="60" Margin="0,20,0,0"
                        MouseDown="Bezel_Click">
                    <TextBlock Text="Bezel"
                               Foreground="White"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Pi Sync -->
                <Border Grid.Row="3" Background="#333" Height="60" Margin="0,20,0,0"
                        MouseDown="PiSync_Click">
                    <TextBlock Text="Pi Sync"
                               Foreground="White"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Tools -->
                <Border Grid.Row="4" Background="#333" Height="60" Margin="0,20,0,0"
                        MouseDown="Tools_Click">
                    <TextBlock Text="Tools"
                               Foreground="White"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

            </Grid>
        </Grid>

    </Grid>
</UserControl>