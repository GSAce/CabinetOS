<UserControl x:Class="CabinetOS.App.Shell.StatusSideBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="350"
             Background="#111111">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- PC STATUS -->
        <Grid Grid.Row="0"
              Height="200"
              Background="#222222"
              Margin="0,0,0,20">
            <TextBlock Text="PC Status"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- PI STATUS -->
        <Grid Grid.Row="1"
              Height="200"
              Background="#222222">
            <TextBlock Text="Pi Status"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

    </Grid>
</UserControl>